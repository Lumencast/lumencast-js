{
  "name": "@lumencast/runtime-vue",
  "version": "0.2.0",
  "description": "Headless Vue 3 adapter for Lumencast — live LSDP/1 leaf state as Vue refs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "homepage": "https://github.com/Lumencast/lumencast-js/tree/main/packages/runtime-vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lumencast/lumencast-js.git",
    "directory": "packages/runtime-vue"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run"
  },
  "dependencies": {
    "@lumencast/protocol": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vue": "^3.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
