{
  "name": "@lumencast/monorepo",
  "version": "0.1.0",
  "description": "Lumencast — TypeScript SDK monorepo (protocol, runtime, server, dev-server)",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Lumencast/lumencast-js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lumencast/lumencast-js.git"
  },
  "bugs": {
    "url": "https://github.com/Lumencast/lumencast-js/issues"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @lumencast/runtime run test:e2e",
    "check:bundle": "pnpm --filter @lumencast/runtime run check:bundle",
    "conformance": "pnpm --filter @lumencast/protocol run conformance",
    "interop:self-test": "node scripts/interop-self-test.mjs",
    "clean": "pnpm -r exec rm -rf dist coverage .tsbuildinfo *.tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.6.0",
    "prettier": "^3.5.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
